{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Kitecast base",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    // Empty on purpose: without this, tsc auto-includes every @types
    // package it finds walking up parent directories, not just this repo's
    // own node_modules. Packages that need ambient types (e.g. "node")
    // declare them explicitly in their own tsconfig.
    "types": []
  }
}
